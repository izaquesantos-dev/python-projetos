import random
import os

def escolher_palavra():
    palavras = ['python', 'dados', 'sistema', 'codigo', 'algoritmo']
    return random.choice(palavras)

def jogar():
    palavra_secreta = escolher_palavra()
    letras_acertadas = ''
    letras_erradas = ''
    tentativas = 0
    max_tentativas = 6

    while True:
        print(f'\nPalavra: {"".join([l if l in letras_acertadas else "*" for l in palavra_secreta])}')
        print(f'Erros: {letras_erradas}')
        print(f'Tentativas: {tentativas}/{max_tentativas}')

        letra = input('Digite uma letra: ').lower()

        if len(letra) != 1:
            print('Digite apenas uma letra.')
            continue

        if letra in letras_acertadas or letra in letras_erradas:
            print('Você já tentou essa letra.')
            continue

        tentativas += 1

        if letra in palavra_secreta:
            letras_acertadas += letra
        else:
            letras_erradas += letra

        if all(l in letras_acertadas for l in palavra_secreta):
            print(f'\n🎉 Você ganhou! Palavra: {palavra_secreta}')
            break

        if tentativas >= max_tentativas:
            print(f'\n💀 Você perdeu! Palavra: {palavra_secreta}')
            break

def menu():
    while True:
        print('\n1 - Jogar')
        print('2 - Sair')
        opcao = input('Escolha: ')

        if opcao == '1':
            os.system('cls' if os.name == 'nt' else 'clear')
            jogar()
        elif opcao == '2':
            break
        else:
            print('Opção inválida.')

menu()
