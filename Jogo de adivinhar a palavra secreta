"""
Um jogo para o usuário adivinhar qual a palavra secreta.
Eu coloquei uma palavra secreta qualquer no caso pyton3 e coloquei a possibilidade para o usuário digitar apenas uma letra.
Quando o usuário digitar uma letra, o programa vai conferir se a letra digitada está na palavra secreta.
Se a letra digitada estiver na palavra secreta a letra será exibida.
Se a letra digitada não estiver na palavra secreta será exibido '*'.
No final tem uma contagem de tentativas.
"""
import os
print('🎮 Vamos brincar de adivinhar a palavra secreta!')
print('Digite apenas uma letra por vez.')

palavra_secreta = 'python3'
letras_acertadas = ''
tentativas = 0
while True:

    letras = input('Qual letra você escolhe? ').lower()
    tentativas += 1

    if len(letras) > 1:
        print('Digite apenas uma letra.')
        continue
    if letras in letras_acertadas:
        print('Você já tentou essa letra.')
        continue
    
    if letras in palavra_secreta:
        letras_acertadas += letras
    
    palavra_formada = ''

    for letra_secreta in palavra_secreta:
        if letra_secreta in letras_acertadas:
            palavra_formada += letra_secreta
        else:
           palavra_formada += '*'

    print(palavra_formada)

    if palavra_secreta == palavra_formada:
        os.system('cls' if os.name == 'nt' else 'clear')
        print('VOCÊ ACERTOU!!!')
        print(f'A palavar era {palavra_secreta}')
        print(f'Tentativas: {tentativas}')
        break
