import os

lista = []

def limpar():
    os.system('cls' if os.name == 'nt' else 'clear')

def inserir():
    item = input('Qual item quer adicionar? ')
    lista.append(item)
    print('Item adicionado!')

def listar():
    if not lista:
        print('Lista vazia.')
        return
    
    for i, item in enumerate(lista):
        print(i, item)

def apagar():
    listar()
    try:
        indice = int(input('Escolha o índice para apagar: '))
        item_removido = lista.pop(indice)
        print(f'Item "{item_removido}" removido.')
    except ValueError:
        print('Digite um número válido.')
    except IndexError:
        print('Índice não existe.')

def menu():
    while True:
        print('\n[i] Inserir  [a] Apagar  [l] Listar  [s] Sair')
        opcao = input('Escolha: ').lower()

        if opcao == 'i':
            inserir()
        elif opcao == 'a':
            apagar()
        elif opcao == 'l':
            listar()
        elif opcao == 's':
            break
        else:
            print('Opção inválida.')

menu()
